# ── Sabre: developer search-only pool (billed to developer) ─────────────
# Used for shop/lookup/seat-map-by-offer when no agency credentials are loaded.
# Obtain from Sabre Dev Studio (CERT account).
SABRE_DEV_ENV=CERT
SABRE_DEV_CLIENT_ID=
SABRE_DEV_CLIENT_SECRET=
SABRE_DEV_PCC=

# ── Agency credentials encryption ───────────────────────────────────────
# 32 bytes, base64-encoded. Generate once with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=

# ── Vercel KV (stores encrypted per-agency Sabre creds) ─────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Neon Auth (multi-tenant orgs == agencies) ───────────────────────────
# Neon Auth is in beta. Create a Neon project, enable Auth + Organizations.
DATABASE_URL=
NEON_AUTH_PROJECT_ID=
NEON_AUTH_PUBLISHABLE_KEY=
NEON_AUTH_SECRET_KEY=

# ── Feature flags (flip to "true" to hit Sabre instead of mocks) ────────
NEXT_PUBLIC_USE_SABRE_AIR=false
NEXT_PUBLIC_USE_SABRE_HOTEL=false
NEXT_PUBLIC_USE_SABRE_CAR=false
NEXT_PUBLIC_USE_SABRE_PNR=false
NEXT_PUBLIC_USE_SABRE_QUEUES=false
NEXT_PUBLIC_USE_SABRE_BOOK_ATPCO=false
NEXT_PUBLIC_USE_SABRE_BOOK_NDC=false
NEXT_PUBLIC_USE_SABRE_TICKET=false
NEXT_PUBLIC_USE_SABRE_TERMINAL=false

# ── Optional debug (dev only; still redacts secrets/PII) ────────────────
SABRE_DEBUG_BODIES=false
